ANTHROPIC_API_KEY=your_api_key_here
VITE_ANTHROPIC_API_KEY=your_api_key_here   # same value — exposed to browser for in-app chat
PORT=3001

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-side only — bypasses RLS to save bot notes)
# Find it in: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Telegram Bot (get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (get it by messaging @userinfobot)
# Comma-separated for multiple users. Leave empty to allow everyone (not recommended).
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Default project UUID to save bot notes to (copy from Supabase field_logs table or app URL)
BOT_DEFAULT_PROJECT_ID=your_project_uuid_here

# OpenAI API key — used for Whisper voice transcription
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Comma-separated list of emails that can see the Admin nav item in the sidebar
VITE_ADMIN_EMAILS=you@example.com

# Google OAuth Client ID — used for Gmail integration (sending RFI drafts)
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add your app URL to "Authorized JavaScript origins" (e.g. http://localhost:5173)
# 4. Add your app URL to "Authorized redirect URIs" as well
# 5. Enable the Gmail API in APIs & Services → Library
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────

# Webhook verify token — choose any random string, paste it in the Meta dashboard too
# Generate with: openssl rand -hex 20
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_here

# Permanent access token for the WhatsApp Business phone number
# Meta dashboard → WhatsApp → API Setup → "Temporary access token" (swap for a System User token in prod)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# 32-byte key used for AES-256-GCM phone number encryption (hex-encoded)
# Generate with: openssl rand -hex 32
# WARNING: rotating this key will break all existing phone lookups — back it up safely
WHATSAPP_PHONE_ENCRYPTION_KEY=your_64_char_hex_key_here

# Redis connection URL — required for BullMQ job queue
# Local dev: redis://localhost:6379
# Cloud: get URL from Upstash, Redis Cloud, or Railway
REDIS_URL=redis://localhost:6379

# xAI Grok API key — get from https://console.x.ai
GROK_API_KEY=your_grok_api_key_here
